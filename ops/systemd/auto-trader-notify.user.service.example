[Unit]
Description=Auto Trader Notification Watcher (User)
After=default.target

[Service]
Type=simple
WorkingDirectory=/home/komug/projects/auto_trader
EnvironmentFile=/home/komug/projects/auto_trader/ops/env/notify.env
ExecStart=/home/komug/projects/auto_trader/.venv/bin/python -m auto_trader.notify --from-env --watch --interval-sec 5 --output-dir data/ops
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
